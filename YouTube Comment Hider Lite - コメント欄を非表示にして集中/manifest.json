{
    "manifest_version": 3,
    "name": "YouTube Comment Hider Lite - コメント欄を非表示にして集中",
    "version": "1.0",
    "description": "YouTubeのコメント欄を非表示にして、不快な言葉やネタバレから身を守る超軽量ツール。",
    "permissions": [],
    "content_scripts": [
        {
            "matches": [
                "https://www.youtube.com/watch?v=*"
            ],
            "css": [
                "style.css"
            ]
        }
    ]
}